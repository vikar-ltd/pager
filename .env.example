# Public hostname of this deployment. Used by Caddy for TLS.
# For local dev, set to "localhost" and use docker-compose.dev.yml.
PAGER_DOMAIN=localhost

# Email for Let's Encrypt ACME registration.
ACME_EMAIL=admin@example.com

# Root-user bootstrap. Used only on first boot to seed the initial `root`
# user in the DB. After that, all user management (including renaming and
# password rotation) goes through the admin UI. Rotating these values here
# does NOT change the root password of an existing user — sign in as root
# and change it via the UI. If every root user is deleted, the seed will
# recreate one with these credentials on next start (recovery path).
#
# ADMIN_USERNAME / ADMIN_PASSWORD are still honored as fallbacks for
# people upgrading from earlier builds.
ROOT_USERNAME=root
ROOT_PASSWORD=changeme

# Internal Mongo connection. Compose defaults are fine.
MONGO_URI=mongodb://mongo:27017
MONGO_DB=pager

# 32-byte random secret used for hashing admin session tokens.
# Rotating this invalidates every existing admin session.
SESSION_PEPPER=replace-me-with-32-random-bytes
