FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/pager ./cmd/pager

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/pager /pager
EXPOSE 8080
ENTRYPOINT ["/pager"]
